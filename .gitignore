.*          → ignore all hidden files/folders
!.gitignore → keep .gitignore tracked
!.git/      → keep git internals (important)

# Compiled binaries (root-level only)
/cloudterm
/forwarder

# Runtime cache
instances_list.yaml
audit.log

# Environment files
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Local data directories
.cache/
.sessionrecordings/
.terminalexport/

# Tests
tests/node_modules/
tests/test-results/

.claude/
.sisyphus/
.suggestdata/
.pi
docs/


# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
AGENTS.md
CLAUDE.md
.beads/
.remember/
taskplane-tasks/
node_modules/
node_modules/
